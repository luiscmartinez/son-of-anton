{
	"name": "codogotchi",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"sync": "bash .son-of-anton/scripts/soa-sync.sh",
		"deliver": "bun run ./scripts/deliver.ts",
		"closeout-stack": "bun run ./scripts/closeout-stack.ts",
		"format": "biome format --write .",
